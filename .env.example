# Supabase project URL (https://<project-ref>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key — safe to expose in browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — server-only, never expose in client code
SUPABASE_SERVICE_ROLE_KEY=

# 관리자 비밀번호 — /admin 인덱스에서 비번 입력 시 내부 모드 cookie 발급.
# 허용 IP 외부에서 임시로 풀 권한 얻을 때 사용. V2에서 OAuth로 대체.
ADMIN_PASSWORD=
